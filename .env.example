# Example environment variables for local development and Render deployment

# Feishu custom app app_id
FEISHU_APP_ID=

# Feishu custom app app_secret
FEISHU_APP_SECRET=

# Feishu bitable app_token
FEISHU_APP_TOKEN=

# Feishu bitable table_id
FEISHU_TABLE_ID=

# Optional: CAS lookup field name in Feishu
FEISHU_SEARCH_FIELD_NAME=客诉号 Ticket Number

# Shared bearer token between Trengo and this service
TRANGO_SHARED_SECRET=

# Optional local port
PORT=5000
